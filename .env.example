# Конфигурация RAG-системы

# === Векторная база данных ===
# Каталог векторной базы RAG: сюда birka-rag-index сохраняет Chroma,
# отсюда birka-rag и профили берут документы для ответов.
RAG_PERSIST_DIR=./storage/chroma/default

# Пути к папкам знаний и/или отдельным файлам (разделитель ; на Windows, : на Unix)
# Рекомендуемая структура:
#   ./knowledge/docs         - документация
#   ./knowledge/code_guides  - безопасные материалы по коду
#   ./knowledge/task_samples - примеры файлов заданий
RAG_SOURCE_PATHS=./knowledge/docs;./knowledge/code_guides;./knowledge/task_samples

# Какие расширения индексировать
RAG_SOURCE_EXTENSIONS=.pdf,.md,.txt,.log,.json,.yaml,.yml,.csv

# Искать файлы во вложенных папках (1 - да, 0 - нет)
RAG_RECURSIVE=1

# Режим индексации: common (одна база на все файлы) или per_file (отдельная база на каждый файл)
RAG_MODE=common

# === Модель эмбеддингов ===
# Модель для создания векторных представлений текста
# Рекомендуемые: d0rj/e5-large-en-ru, intfloat/multilingual-e5-large
RAG_MODEL_NAME=d0rj/e5-large-en-ru

# === Профиль LLM ===
# Активный профиль: ollama_local, gigachat, openai_cloud, openrouter, groq, deepseek, apifreellm
RAG_PROFILE=ollama_local

# Каталог для файлов, загружаемых пользователем в чат (traceback/task files)
RAG_UPLOADS_DIR=./storage/uploads

# Кэш моделей Hugging Face. По умолчанию ~/.cache/huggingface.
# Чтобы хранить модели на диске E: (например E:\lm), раскомментируйте:
# HF_HOME=E:\lm
# TRANSFORMERS_CACHE=E:\lm\hub

# Демонстрационный вопрос для теста
RAG_DEMO_QUESTION=query: какие есть схемно-режимные мероприятия?

# === API ключи для сетевых LLM ===

# GigaChat (https://developers.sber.ru/studio)
# GIGACHAT_API_KEY=ваш_ключ_авторизации
# GIGACHAT_CLIENT_ID=uuid_приложения  # опционально
# GIGACHAT_VERIFY_SSL_CERTS=1  # 0 для отключения проверки SSL

# OpenAI
# OPENAI_API_KEY=sk-...

# OpenRouter (https://openrouter.ai)
# OPENROUTER_API_KEY=sk-or-...

# Groq (https://console.groq.com)
# GROQ_API_KEY=gsk_...

# DeepSeek (https://platform.deepseek.com)
# DEEPSEEK_API_KEY=sk-...

# ApiFreeLLM (https://apifreellm.com)
# APIFREELLM_API_KEY=...

# === Дополнительные настройки ===

# Путь к CA bundle для SSL (опционально)
# RAG_CA_BUNDLE_FILE=/path/to/ca-bundle.crt
# GIGACHAT_CA_BUNDLE_FILE=/path/to/gigachat-ca.crt
