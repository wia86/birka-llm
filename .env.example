# Каталог векторной базы RAG: сюда create_rag сохраняет базу, отсюда run_lln берёт документы для ответов
RAG_PERSIST_DIR=./storage/chroma/default

# Пути к папкам знаний и/или к отдельным файлам (разделитель ; на Windows, : на Linux/macOS)
# Рекомендуемая структура:
#   ./knowledge/docs         - документация
#   ./knowledge/code_guides  - безопасные материалы по коду
#   ./knowledge/task_samples - примеры заданий
RAG_SOURCE_PATHS=./knowledge/docs;./knowledge/code_guides;./knowledge/task_samples

# Какие расширения индексировать
RAG_SOURCE_EXTENSIONS=.pdf,.md,.txt,.log,.json,.yaml,.yml,.csv

# Искать файлы во вложенных папках (1) или только в корне каждой папки (0). По умолчанию 1
# RAG_RECURSIVE=1

# Режим базы: common — одна общая RAG на все файлы; per_file — отдельная RAG на каждый PDF
# RAG_MODE=common

# Модель эмбеддингов. По умолчанию d0rj/e5-large-en-ru (русский+английский).
# Для E5-моделей префиксы query:/passage: подставляются автоматически.
# Альтернативы: BAAI/bge-m3, intfloat/multilingual-e5-large
# RAG_MODEL_NAME=d0rj/e5-large-en-ru

# Каталог для файлов, загруженных пользователем в чат (traceback/task files)
RAG_UPLOADS_DIR=./storage/uploads

# Кэш моделей Hugging Face. По умолчанию ~/.cache/huggingface.
# Чтобы хранить модели на диске E: (например E:\lm), раскомментируйте:
# HF_HOME=E:\lm
# TRANSFORMERS_CACHE=E:\lm\hub

# --- Профиль LLM для RAG-чата (run_lln.py). RAG_* = настройки этого чата. ---
# Варианты: ollama_local | gigachat | openai_cloud | openrouter | groq
# ollama_local = локальная Ollama на этом ПК (без облака), задаётся в rag_assistant/profiles.py
# RAG_PROFILE=ollama_local

# Облачная модель по умолчанию (если RAG_PROFILE не задан):
# RAG_CLOUD_MODEL=gigachat

# Ключи под профили: gigachat | openai_cloud | openrouter | groq | deepseek
# DEEPSEEK_API_KEY=...  (https://platform.deepseek.com/api_keys)
# GIGACHAT_API_KEY=...
# Для GigaChat в сетях с корпоративным MITM-сертификатом:
# GIGACHAT_CA_BUNDLE_FILE=C:\certs\corp-root.pem
# Временный обход (небезопасно, только для диагностики):
# GIGACHAT_VERIFY_SSL_CERTS=0
# OPENAI_API_KEY=...
# OPENROUTER_API_KEY=...
# GROQ_API_KEY=...
# Anthropic (Claude) — через профиль openrouter, модель anthropic/claude-3.5-sonnet
# ANTHROPIC_API_KEY=...  (для других скриптов; в RAG-чате Claude — через OpenRouter)
